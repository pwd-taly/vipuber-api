# VipUber Booking API — Configuration

# Required: Your VipUber login credentials
VIPUBER_EMAIL=your@email.com
VIPUBER_PASSWORD=yourpassword

# Optional: API server configuration
HOST=0.0.0.0
PORT=8222

# Optional: Base URL of the VipUber PHP server
VIPUBER_BASE_URL=https://booking.vipuber.net

# Optional: Default customer/company ID for your account
VIPUBER_CUSTOMER_ID=447

# Required: Protects the REST layer. Send this as the X-API-Key header.
# Use a long random value; do not reuse your VipUber password.
API_KEY=change-me-to-a-long-random-secret

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
